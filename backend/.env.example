# ─────────────────────────────────────────────────────────────────────────────
# Lumio Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Lumio API
APP_VERSION=1.0.0
ENVIRONMENT=production          # production | staging | development
DEBUG=false
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://your-lumio-site.vercel.app,https://lumio.yourdomain.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_FETCH=30/minute      # /api/fetch-info — per IP
RATE_LIMIT_DOWNLOAD=10/minute   # /api/download   — per IP

# ── Download limits ───────────────────────────────────────────────────────────
MAX_VIDEO_DURATION_SECONDS=10800    # 3 hours — refuse longer videos
DOWNLOAD_TIMEOUT_SECONDS=600        # 10 minutes — kill stalled downloads
TMP_DIR=/tmp/lumio_downloads        # temp directory for in-progress files
CLEANUP_AFTER_SECONDS=300           # delete temp files after 5 minutes

# ── yt-dlp cookies (optional) ─────────────────────────────────────────────────
# Helps with age-restricted or geo-restricted videos.
# Export cookies from your browser using a cookies.txt extension.
COOKIES_FILE=                       # e.g. /app/cookies.txt  (leave empty to disable)
